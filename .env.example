# Local app URL
APP_URL="http://localhost:8050"

# ---------------------------------------------------------------------------
# Local control-plane + storage worker
# ---------------------------------------------------------------------------
# URL of the InfluxDB v2 service.
# Local dev: http://localhost:8086
INFLUXDB_URL="http://localhost:8086"

# InfluxDB operator token – generate with `influx auth create` or from the UI.
INFLUXDB_TOKEN="MY_INFLUXDB_TOKEN"

# Organisation and bucket created during InfluxDB initialisation.
INFLUXDB_ORG="zedd-weather"
INFLUXDB_BUCKET="telemetry"

# InfluxDB admin credentials (used only during first-time setup / docker-compose)
DOCKER_INFLUXDB_INIT_USERNAME="admin"
DOCKER_INFLUXDB_INIT_PASSWORD="changeme-password"
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN="changeme-token"

# ---------------------------------------------------------------------------
# Local AI worker (or remote AI host)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL="http://10.0.0.20:11434"
OLLAMA_MODEL="gemma2:2b"

# ---------------------------------------------------------------------------
# AccuWeather forecast API (used by node2 orchestration — server-side only)
# ---------------------------------------------------------------------------
ACCUWEATHER_API_KEY="MY_ACCUWEATHER_API_KEY"

# ---------------------------------------------------------------------------
# Cryptographic attestation (node2 orchestration — server-side only)
# ---------------------------------------------------------------------------
# HMAC-SHA512 signing key for attestation payloads (generate with: openssl rand -hex 64)
ATTESTATION_HMAC_KEY="REPLACE_WITH_RANDOM_64_BYTE_HEX_STRING"

# ---------------------------------------------------------------------------
# Google Weather API (server-side — used by FastAPI backend for weather proxy)
# ---------------------------------------------------------------------------
# Both the old Vite-injected key and the new server-side key are accepted.
# Set GOOGLE_WEATHER_API_KEY for the Python backend/dashboard.
GOOGLE_WEATHER_API_KEY="MY_GOOGLE_WEATHER_API_KEY"

# Legacy Vite frontend key (still needed if running the React dev server)
VITE_GOOGLE_WEATHER_API_KEY="MY_GOOGLE_WEATHER_API_KEY"

# ---------------------------------------------------------------------------
# Edge sensor configuration (node1 telemetry / pinet-rho)
# ---------------------------------------------------------------------------
SENSE_HAT_ENABLED="true"
SENSE_HAT_TEMP_OFFSET="2.0"
RAIN_GAUGE_ENABLED="false"
UV_SENSOR_ENABLED="false"
ENVIRO_PLUS_ENABLED="false"
MODBUS_ENABLED="false"

# ---------------------------------------------------------------------------
# AI HAT+ (Hailo-8L NPU – M.2 Key E accelerator)
# ---------------------------------------------------------------------------
AI_HAT_ENABLED="true"
AI_HAT_MODEL_PATH="/opt/zedd/models/weather_classify.hef"
AI_HAT_DEVICE_ID="/dev/hailo0"

# ---------------------------------------------------------------------------
# M.2 NVMe SSD storage (optional – for faster telemetry buffering)
# ---------------------------------------------------------------------------
M2_NVME_ENABLED="false"
M2_NVME_PATH="/mnt/nvme"

# How often (seconds) to read sensors and push to InfluxDB
PUBLISH_INTERVAL="10.0"

# ---------------------------------------------------------------------------
# MQTT broker (used by three-node cluster simulation)
# ---------------------------------------------------------------------------
MQTT_BROKER_HOST="localhost"
MQTT_BROKER_PORT="1883"
MQTT_TOPIC="weather_station/telemetry"

# Alert thresholds
ALERT_TEMP_HIGH_C="35.0"
ALERT_TEMP_LOW_C="0.0"
ALERT_WIND_SPEED_MS="20.0"
ALERT_UV_INDEX="8.0"
ALERT_AQI="150.0"
