# Zedd Weather – Production Environment Configuration
# ---------------------------------------------------------------------------
# DO NOT commit real secrets.  Fill in values via your CI/CD secret manager
# (e.g. GitHub Actions Secrets or Vault) before deploying.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Frontend / App
# ---------------------------------------------------------------------------
NODE_ENV=production
APP_URL=https://weather.pinet.local

# ---------------------------------------------------------------------------
# InfluxDB – control-plane + storage worker endpoint
# ---------------------------------------------------------------------------
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=REPLACE_WITH_PRODUCTION_TOKEN
INFLUXDB_ORG=zedd-weather
INFLUXDB_BUCKET=telemetry

# ---------------------------------------------------------------------------
# Ollama – pinet-sigma
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://10.0.0.20:11434
OLLAMA_MODEL=gemma2:2b

# ---------------------------------------------------------------------------
# AccuWeather (server-side macro-forecasts)
# ---------------------------------------------------------------------------
ACCUWEATHER_API_KEY=REPLACE_WITH_ACCUWEATHER_API_KEY

# ---------------------------------------------------------------------------
# Google Weather API (frontend current conditions & forecasts)
# ---------------------------------------------------------------------------
VITE_GOOGLE_WEATHER_API_KEY=REPLACE_WITH_GOOGLE_WEATHER_API_KEY

# ---------------------------------------------------------------------------
# Edge sensor (pinet-rho / node1)
# ---------------------------------------------------------------------------
SENSE_HAT_ENABLED=true
SENSE_HAT_TEMP_OFFSET=2.0
RAIN_GAUGE_ENABLED=false
UV_SENSOR_ENABLED=false
ENVIRO_PLUS_ENABLED=false
MODBUS_ENABLED=false
PUBLISH_INTERVAL=10.0

# ---------------------------------------------------------------------------
# AI HAT+ (Hailo-8L NPU – M.2 Key E accelerator)
# ---------------------------------------------------------------------------
AI_HAT_ENABLED=true
AI_HAT_MODEL_PATH=/opt/zedd/models/weather_classify.hef
AI_HAT_DEVICE_ID=/dev/hailo0

# ---------------------------------------------------------------------------
# M.2 NVMe SSD storage
# ---------------------------------------------------------------------------
M2_NVME_ENABLED=true
M2_NVME_PATH=/mnt/nvme

# Alert thresholds
ALERT_TEMP_HIGH_C=35.0
ALERT_TEMP_LOW_C=0.0
ALERT_WIND_SPEED_MS=20.0
ALERT_UV_INDEX=8.0
ALERT_AQI=150.0

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
